{
  "name": "@mmerlone/mui7-phone-number",
  "version": "2.0.0",
  "description": "Phone number input component compatible with MUI v7",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "demo": "pnpm -C demo run dev",
    "demo:build": "pnpm -C demo run build",
    "demo:preview": "pnpm -C demo run preview",
    "prepare": "husky",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmerlone/mui7-phone-number"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "material",
    "react",
    "phone",
    "format",
    "telephone",
    "countries",
    "international"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mmerlone/mui7-phone-number/issues"
  },
  "homepage": "https://github.com/mmerlone/mui7-phone-number",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "country-flag-icons": "^1.5.11"
  },
  "peerDependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@mui/material": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
